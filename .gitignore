# ─── CoversCart Monorepo .gitignore ─────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
node_modules.bak/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
.next/

# ── Environment variables — NEVER commit secrets ──────────────────────────────
.env
.env.local
.env.production
.env.development.local
.env.test.local
.env.production.local

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Editor ───────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.local

# ── Prisma ────────────────────────────────────────────────────────────────────
backend/prisma/migrations/

# ── Backup files ─────────────────────────────────────────────────────────────
*.bak
package-lock.json.bak
package.json.bak
