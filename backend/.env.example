# ─── CoversCart Backend Environment Variables ────────────────────────────────
#
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
#
# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ── CORS — allowed frontend origins ──────────────────────────────────────────
FRONTEND_URL=https://coverscart.com
ADMIN_URL=https://admin.coverscart.com
# Local dev:
# FRONTEND_URL=http://localhost:3000
# ADMIN_URL=http://localhost:3001

# ── Supabase (public client) ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_public_anon_key_here

# ── Database (Prisma / PostgreSQL) ───────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coverscart?schema=public"
# Production example (Supabase direct connection):
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ── JWT (own auth — legacy/fallback) ─────────────────────────────────────────
# Must be a strong random secret in production (use: openssl rand -hex 64)
JWT_SECRET=change_me_to_a_strong_random_secret_in_production

# ── Supabase JWT Verification ─────────────────────────────────────────────────
# Find this in: Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ── Cloudinary (image storage) ───────────────────────────────────────────────
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
# Or, use separate Cloudinary values:
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ── Razorpay (payments) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
